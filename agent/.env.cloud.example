# Cloud runtime profile.
# Do not commit real secret values. Put API keys in AWS Secrets Manager or
# GitHub Actions secrets, and keep account-specific IDs in repository variables.

APP_NAME=SuperBizAgent
APP_VERSION=1.0.0
DEBUG=false
HOST=0.0.0.0
PORT=9900

LLM_PROVIDER=openai
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5.4-nano
RAG_MODEL=gpt-5.4-nano
DASHSCOPE_MODEL=qwen-max
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v4

# Current ECS deployment uses an EC2-hosted Milvus instance.
MILVUS_HOST=<milvus-private-ip-or-dns>
MILVUS_PORT=19530
MILVUS_TIMEOUT=10000
MILVUS_CONNECT_ON_STARTUP=true

RAG_TOP_K=3
CHUNK_MAX_SIZE=800
CHUNK_OVERLAP=100

# The cloud task runs backend, CLS MCP, and Monitor MCP together.
# Backend reaches MCP containers through the shared ECS task network namespace.
MCP_CLS_TRANSPORT=streamable-http
MCP_CLS_URL=http://127.0.0.1:8003/mcp
CLS_MODE=cloudwatch
MCP_MONITOR_TRANSPORT=streamable-http
MCP_MONITOR_URL=http://127.0.0.1:8004/mcp

PROMETHEUS_BASE_URL=<aws-managed-prometheus-workspace-url>
PROMETHEUS_REQUEST_TIMEOUT=10.0
PROMETHEUS_AUTH_TYPE=sigv4
PROMETHEUS_SIGV4_REGION=ap-southeast-2
PROMETHEUS_SIGV4_SERVICE=aps
