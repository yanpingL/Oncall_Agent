# Local Docker Compose profile.
# Copy to .env.local and fill in at least one LLM API key.

APP_NAME=SuperBizAgent
APP_VERSION=1.0.0
DEBUG=false
HOST=0.0.0.0
PORT=9900

LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5.4-nano
RAG_MODEL=gpt-5.4-nano

DASHSCOPE_API_KEY=
DASHSCOPE_MODEL=qwen-max
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v4

MILVUS_HOST=standalone
MILVUS_PORT=19530
MILVUS_TIMEOUT=10000
MILVUS_CONNECT_ON_STARTUP=true

RAG_TOP_K=3
CHUNK_MAX_SIZE=800
CHUNK_OVERLAP=100

MCP_CLS_TRANSPORT=streamable-http
MCP_CLS_URL=http://cls-mcp:8003/mcp
CLS_MODE=demo
CLS_DEMO_LOGS_PATH=demo-data/cls_logs.json
MCP_MONITOR_TRANSPORT=streamable-http
MCP_MONITOR_URL=http://monitor-mcp:8004/mcp

PROMETHEUS_BASE_URL=http://prometheus:9090
PROMETHEUS_REQUEST_TIMEOUT=10.0
PROMETHEUS_AUTH_TYPE=none
PROMETHEUS_SIGV4_REGION=ap-southeast-2
PROMETHEUS_SIGV4_SERVICE=aps
